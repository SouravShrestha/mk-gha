name: CI Feature

on:
  push:
    branches-ignore:
      - main

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  ci-feature:
    runs-on: ubuntu-latest
    environment: test

    steps:
      - name: Checkout code
        uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2

<% if (projectType === 'dotnet') { -%>
      - name: Setup .NET
        uses: actions/setup-dotnet@87b7050bc53ea08284295505d98d2aa94301e852 # v4.2.0
        with:
          dotnet-version: '<%= dotnetVersion %>'

      - name: Restore dependencies
        run: dotnet restore

      - name: Build
        run: dotnet build --configuration Release --no-restore

<% if (testRunner === 'xunit') { -%>
      - name: Run tests
        run: dotnet test --configuration Release --no-build
<% } else { -%>
      - name: Run tests
        run: npm test -- --watchAll=false
<% } -%>
<% } else { -%>
      - name: Setup Node.js
        uses: actions/setup-node@39370e3970a6d050c480ffad4ff0ed4d3fdee5af # v4.1.0
        with:
          node-version: <%= nodeVersion %>
          cache: npm

      - name: Restore dependencies
        run: npm ci

      - name: Build
        run: npm run build

<% if (hasLint) { -%>
      - name: Lint
        run: npm run lint

<% } -%>
      - name: Run tests
        run: <%= testRunner === 'vitest' ? 'npx vitest run' : 'npm test -- --watchAll=false' %>
<% } -%>

<% if (deployTargets.includes('cloudflare')) { -%>
      - name: Deploy to Cloudflare Workers TEST
        uses: cloudflare/wrangler-action@6d58852c35a27e6034745c5d0bc373d739014f7f # v3.13.0
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          command: deploy --env test
<% } -%>
