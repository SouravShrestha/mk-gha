name: CI Main

on:
  push:
    branches:
      - main

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: false

<%
const hasArtifactTargets = deployTargets.some(t => t === 'npm' || t === 'cloudflare');
const hasDockerTargets = deployTargets.some(t => t === 'docker' || t === 'github-packages');
-%>

permissions:
  contents: read

jobs:
  ci:
    runs-on: ubuntu-latest
    environment: test

    steps:
      - name: Checkout code
        uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2

<% if (projectType === 'dotnet') { -%>
      - name: Setup .NET
        uses: actions/setup-dotnet@87b7050bc53ea08284295505d98d2aa94301e852 # v4.2.0
        with:
          dotnet-version: '<%= dotnetVersion %>'

      - name: Restore dependencies
        run: dotnet restore

      - name: Build
        run: dotnet build --configuration Release --no-restore

<% if (testRunner === 'xunit') { -%>
      - name: Run tests
        run: dotnet test --configuration Release --no-build
<% } else { -%>
      - name: Run tests
        run: npm test -- --watchAll=false
<% } -%>

      - name: Publish
        run: dotnet publish --configuration Release --no-build --output ./publish

<% } else { -%>
      - name: Setup Node.js
        uses: actions/setup-node@39370e3970a6d050c480ffad4ff0ed4d3fdee5af # v4.1.0
        with:
          node-version: <%= nodeVersion %>
          cache: npm

      - name: Restore dependencies
        run: npm ci

      - name: Build
        run: npm run build

<% if (hasLint) { -%>
      - name: Lint
        run: npm run lint

<% } -%>
      - name: Run tests
        run: <%= testRunner === 'vitest' ? 'npx vitest run' : 'npm test -- --watchAll=false' %>

<% } -%>
<% if (deployTargets.includes('cloudflare')) { -%>
      - name: Deploy to Cloudflare Workers TEST
        uses: cloudflare/wrangler-action@6d58852c35a27e6034745c5d0bc373d739014f7f # v3.13.0
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          command: deploy --env test

<% } -%>
      - name: Upload build artifact
        uses: actions/upload-artifact@b4b15b8c7c6ac21ea08fcf65892d2ee8f75cf882 # v4.4.3
        with:
          name: build-${{ github.sha }}
          # Adjust this path if your build outputs to a different directory
          path: <%= artifactPath %>
          retention-days: 7

  release-please:
    needs: ci
    runs-on: ubuntu-latest
    permissions:
      contents: write
      pull-requests: write
    outputs:
      release_created: ${{ steps.release.outputs.release_created }}
      tag_name: ${{ steps.release.outputs.tag_name }}
    steps:
      - name: Run release-please
        id: release
        uses: googleapis/release-please-action@7987652d64b4581673a76e33ad5e98e3dd56832f # v4.1.3
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          config-file: .github/release-please-config.json
          manifest-file: .github/.release-please-manifest.json

  cd-prod:
    needs: release-please
    if: ${{ needs.release-please.outputs.release_created == 'true' }}
    runs-on: ubuntu-latest
    environment: production
    permissions:
      contents: read
<% if (deployTargets.includes('github-packages')) { -%>
      packages: write
<% } -%>
<% if (hasArtifactTargets) { -%>
      actions: read
<% } -%>

    steps:
      - name: Checkout code
        uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
        with:
          ref: ${{ needs.release-please.outputs.tag_name }}

<% if (hasArtifactTargets) { -%>
      - name: Download build artifact
        uses: actions/download-artifact@fa0a91b85d4f404e444e00e005971372dc801d16 # v4.1.8
        with:
          name: build-${{ github.sha }}
          path: <%= artifactPath %>

<% } else { -%>
<%   if (projectType === 'dotnet') { -%>
      - name: Setup .NET
        uses: actions/setup-dotnet@87b7050bc53ea08284295505d98d2aa94301e852 # v4.2.0
        with:
          dotnet-version: '<%= dotnetVersion %>'

      - name: Restore dependencies
        run: dotnet restore

      - name: Build
        run: dotnet build --configuration Release --no-restore



      - name: Publish
        run: dotnet publish --configuration Release --no-build --output ./publish

<%   } else { -%>
      - name: Setup Node.js
        uses: actions/setup-node@39370e3970a6d050c480ffad4ff0ed4d3fdee5af # v4.1.0
        with:
          node-version: <%= nodeVersion %>
          cache: npm

      - name: Restore dependencies
        run: npm ci

      - name: Build
        run: npm run build

<%     if (hasLint) { -%>
      - name: Lint
        run: npm run lint

<%     } -%>


<%   } -%>
<% } -%>
<% if (hasDockerTargets) { -%>
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@c47758b77c9736f4b2ef4073d4d51994fabfe349 # v3.7.1

<% } -%>
<% if (deployTargets.includes('docker')) { -%>
      - name: Log in to Docker Hub
        uses: docker/login-action@9780b0c442fbb1117ed29e0efdff1e18412f7567 # v3.3.0
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      - name: Build and push PROD image
        uses: docker/build-push-action@48aba3b46d1b1fec4febb7c5d0c644b249a11355 # v6.10.0
        with:
          context: .
          push: true
          cache-from: type=gha
          cache-to: type=gha,mode=max
          tags: |
            ${{ secrets.DOCKER_USERNAME }}/${{ github.event.repository.name }}:latest
            ${{ secrets.DOCKER_USERNAME }}/${{ github.event.repository.name }}:${{ github.ref_name }}
<% } -%>
<% if (deployTargets.includes('cloudflare')) { -%>
      - name: Deploy to Cloudflare Workers PROD
        uses: cloudflare/wrangler-action@6d58852c35a27e6034745c5d0bc373d739014f7f # v3.13.0
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          command: deploy --env production
<% } -%>
<% if (deployTargets.includes('github-packages')) { -%>
      - name: Log in to GitHub Container Registry
        uses: docker/login-action@9780b0c442fbb1117ed29e0efdff1e18412f7567 # v3.3.0
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Build and push PROD image to GHCR
        uses: docker/build-push-action@48aba3b46d1b1fec4febb7c5d0c644b249a11355 # v6.10.0
        with:
          context: .
          push: true
          cache-from: type=gha
          cache-to: type=gha,mode=max
          tags: |
            ghcr.io/${{ github.repository }}:latest
            ghcr.io/${{ github.repository }}:${{ github.ref_name }}
<% } -%>
<% if (deployTargets.includes('npm')) { -%>
      - name: Setup Node.js for publish
        uses: actions/setup-node@39370e3970a6d050c480ffad4ff0ed4d3fdee5af # v4.1.0
        with:
          node-version: <%= nodeVersion %>
          registry-url: 'https://registry.npmjs.org'

      - name: Publish to npm
        run: npm publish --ignore-scripts<%= npmPublicAccess ? ' --access public' : '' %>
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}
<% } -%>
